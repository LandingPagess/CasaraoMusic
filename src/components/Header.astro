      target="_blank"
      rel="noopener noreferrer"
      class="mobile-nav-link flex items-center justify-center gap-2 py-4 rounded-2xl text-base font-bold transition-all duration-200 active:scale-95"
      style="background-color: var(--color-primary); color: #000;"
    >
