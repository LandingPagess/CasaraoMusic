---
const WA_URL =
  'https://api.whatsapp.com/send?phone=5571992984280&text=Ol%C3%A1!%20Quero%20saber%20sobre%20reservas%20no%20Casar%C3%A3o%20Music.';

const navLinks = [
  { label: 'Home', href: '#home' },
  { label: 'Programação', href: '#programacao' },
  { label: 'Estrutura', href: '#sobre' },
  { label: 'Galeria', href: '#galeria' },
  { label: 'Reservas', href: '#reservas' },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href="#home" class="shrink-0">
        <picture>
          <source srcset="/images/logo.webp" type="image/webp" />
          <img
            src="/images/logo.png"
            alt="Casarão Music"
            class="h-14 md:h-16 w-auto object-contain"
            width="128"
            height="128"
            fetchpriority="high"
          />
        </picture>
      </a>

      <!-- Nav Desktop -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-sm font-medium tracking-wide transition-all duration-200 pb-0.5"
            style="color: var(--color-cream);"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-pulse hidden sm:inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-bold
                 transition-all duration-300 hover:scale-105 ring-2"
          style="background-color: var(--color-primary); color: #000;
                 ring-color: rgba(212,160,23,0.2);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Reservar Agora
        </a>

        <!-- Hamburger -->
        <button
          id="menu-toggle"
          class="md:hidden w-10 h-10 flex items-center justify-center rounded-full transition-colors"
          style="color: var(--color-primary); background: rgba(212,160,23,0.08);"
          aria-label="Abrir menu"
          aria-expanded="false"
        >
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay (full-screen) -->
<div
  id="mobile-menu"
  class="md:hidden fixed inset-0 z-[60] flex flex-col"
  aria-hidden="true"
>
  <!-- Top bar: logo + close -->
  <div
    class="flex items-center justify-between px-5 shrink-0"
    style="height: 64px; border-bottom: 1px solid rgba(212,160,23,0.15);"
  >
    <a href="#home" id="mobile-logo-link" class="shrink-0">
      <picture>
        <source srcset="/images/logo.webp" type="image/webp" />
        <img src="/images/logo.png" alt="Casarão Music" class="h-12 w-auto object-contain" width="128" height="128" />
      </picture>
    </a>
    <button
      id="menu-close"
      aria-label="Fechar menu"
      class="w-10 h-10 flex items-center justify-center rounded-full transition-colors"
      style="color: var(--color-cream); background: rgba(255,255,255,0.07);"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav class="flex-1 flex flex-col justify-center px-8">
    {navLinks.map((link, i) => (
      <a
        href={link.href}
        class="mobile-nav-link group flex items-center justify-between py-5"
        style="border-bottom: 1px solid rgba(255,255,255,0.06); color: var(--color-cream);"
      >
        <div class="flex items-baseline gap-3">
          <span class="text-xs font-mono" style="color: rgba(212,160,23,0.5);">0{i + 1}</span>
          <span
            class="text-2xl font-semibold tracking-wide transition-colors duration-200 group-hover:text-[#D4A017]"
            style="font-family: var(--font-playfair);"
          >{link.label}</span>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-30 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200" style="color: var(--color-primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    ))}
  </nav>

  <!-- Bottom: CTA + social -->
  <div class="px-6 pb-10 pt-5 flex flex-col gap-5 shrink-0">
    <a
