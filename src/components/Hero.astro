---
const WA_URL =
  'https://api.whatsapp.com/send?phone=5571992984280&text=Ol%C3%A1!%20Quero%20reservar%20uma%20mesa%20no%20Casar%C3%A3o%20Music.';
---

<section
  id="home"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background Image with blur -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?w=1440&q=65&auto=format&fm=webp"
      alt="Show ao vivo no Casarão Music com luzes de palco"
      class="w-full h-full object-cover object-center"
      style="filter: blur(2px); transform: scale(1.04);"
      width="1920"
      height="1080"
      fetchpriority="high"
    />
    <!-- Layer 1: main gradient -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.75) 100%);"
    ></div>
    <!-- Layer 2: warm radial accent -->
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse at 70% 50%, rgba(212,160,23,0.15) 0%, transparent 60%);"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center pt-20">

    <!-- Google badge -->
    <div
      class="animate-fade-in-up inline-flex items-center gap-2 px-4 py-2 rounded-full mb-8 text-sm font-medium"
      style="background-color: rgba(212,160,23,0.12); border: 1px solid rgba(212,160,23,0.35); color: var(--color-primary);"
    >
      <span aria-hidden="true" style="letter-spacing: 1px;">★★★★★</span>
      <span class="text-xs" style="color: rgba(245,240,232,0.9);">4.5 no Google · Centenas de avaliações</span>
    </div>

    <!-- Headline -->
    <h1
      class="animate-fade-in-up delay-200 text-5xl sm:text-6xl md:text-7xl font-bold leading-tight mb-6"
      style="font-family: var(--font-playfair); color: var(--color-cream);"
    >
      A Noite Tem um<br />
      <em class="not-italic" style="color: var(--color-primary); font-style: italic;">Endereço</em>
      <span> em Salvador.</span>
    </h1>

    <!-- Subheadline -->
    <p
      class="animate-fade-in-up delay-300 text-base sm:text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed"
      style="color: rgba(245, 240, 232, 0.85);"
    >
      Música ao vivo, drinks premiados e uma atmosfera que você não vai esquecer.
      Toda semana, o melhor da noite baiana no Casarão Music.
    </p>

    <!-- CTAs -->
    <div class="animate-fade-in-up delay-500 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#programacao"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-bold text-base
               transition-all duration-300 hover:scale-105 hover:shadow-xl w-full sm:w-auto justify-center
               shadow-lg ring-2"
        style="background-color: var(--color-primary); color: #000;
               box-shadow: 0 8px 24px rgba(212,160,23,0.4);
               ring-color: rgba(212,160,23,0.2);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
        </svg>
        Ver Programação
      </a>

      <a
        href={WA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-bold text-base
               transition-all duration-300 hover:scale-105 w-full sm:w-auto justify-center"
        style="border: 2px solid var(--color-primary); color: var(--color-primary); background: rgba(212,160,23,0.06);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Reservar Mesa no WhatsApp
      </a>
    </div>
  </div>

  <!-- Scroll arrow -->
  <div class="animate-bounce absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5">
    <span class="text-[10px] tracking-[0.25em] uppercase" style="color: rgba(212,160,23,0.7);">Role</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" style="color: var(--color-primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
