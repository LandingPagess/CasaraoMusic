---
const WA_INGRESSO =
  'https://api.whatsapp.com/send?phone=55XXXXXXXXXX&text=Ol%C3%A1!%20Quero%20garantir%20meu%20ingresso%20para%20o%20show%20no%20Casar%C3%A3o%20Music.';

const genreBadge: Record<string, { bg: string; text: string }> = {
  'Samba & Pagode': { bg: '#EAB308', text: '#000' },
  'Forró Roots':    { bg: '#F97316', text: '#fff' },
  'Rock Nacional':  { bg: '#DC2626', text: '#fff' },
  'MPB & Bossa Nova': { bg: '#9333EA', text: '#fff' },
  'Axé & Pop Baiano': { bg: '#D4A017', text: '#000' },
  'Jazz & Blues':   { bg: '#2563EB', text: '#fff' },
};

const eventos = [
  {
    diaSemana: 'Sexta-feira',
    data: '14/03',
    artista: 'Grupo Semente',
    estilo: 'Samba & Pagode',
    descricao: 'O samba raiz de volta às raízes com o Grupo Semente. Uma noite de muito pagode, emoção e brasilidade pura.',
    tag: 'EM DESTAQUE',
    destaque: true,
  },
  {
    diaSemana: 'Sábado',
    data: '15/03',
    artista: 'Banda Nordestina',
    estilo: 'Forró Roots',
    descricao: 'O melhor do forró pé-de-serra com arranjos modernos. Sanfona, zabumba e triângulo ao vivo.',
    tag: 'Imperdível',
    destaque: false,
  },
  {
    diaSemana: 'Sexta-feira',
    data: '21/03',
    artista: 'Noite do Rock',
    estilo: 'Rock Nacional',
    descricao: 'Uma noite dedicada ao rock brasileiro com as melhores bandas da cena local de Salvador.',
    tag: 'Novo',
    destaque: false,
  },
  {
    diaSemana: 'Sábado',
    data: '22/03',
    artista: 'Clube do MPB',
    estilo: 'MPB & Bossa Nova',
    descricao: 'As melodias que definiram o Brasil, revividas com um toque contemporâneo e muito estilo.',
    tag: null,
    destaque: false,
  },
  {
    diaSemana: 'Sexta-feira',
    data: '28/03',
    artista: 'Axé Eletro',
    estilo: 'Axé & Pop Baiano',
    descricao: 'A energia elétrica do axé baiano em uma festa que vai sacudir todo o Casarão Music.',
    tag: 'Destaque',
    destaque: false,
  },
  {
    diaSemana: 'Sábado',
    data: '29/03',
    artista: 'Jazz & Blues Night',
    estilo: 'Jazz & Blues',
    descricao: 'Uma noite sofisticada com jazz e blues ao vivo. Perfeito para quem aprecia a música instrumental.',
    tag: null,
    destaque: false,
  },
];
---

<section id="programacao" class="py-24 md:py-32" style="background-color: var(--color-dark);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14" data-animate>
      <div class="flex items-center gap-3 justify-center mb-4">
        <div class="h-px w-12" style="background: var(--color-primary);"></div>
        <span class="text-xs uppercase tracking-[0.3em] font-medium" style="color: var(--color-primary);">Março 2025</span>
        <div class="h-px w-12" style="background: var(--color-primary);"></div>
      </div>
      <h2
        class="text-4xl md:text-5xl font-bold mb-4"
        style="font-family: var(--font-playfair); color: var(--color-cream);"
      >
        Agenda do Mês
      </h2>
      <p class="max-w-xl mx-auto text-sm md:text-base" style="color: var(--color-cream-muted);">
        Garanta seu lugar antes que esgote. Toda semana tem show novo no Casarão.
      </p>
    </div>

    <!-- Events grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {eventos.map((evento, i) => {
        const badge = genreBadge[evento.estilo];
        const isDestaque = evento.destaque;
        const delay = String((i % 3) + 1);
        return (
          <article
            data-animate
            data-animate-delay={delay}
            class={`group flex flex-col rounded-2xl overflow-hidden transition-all duration-300
              hover:-translate-y-1 hover:shadow-2xl relative
              ${isDestaque ? 'lg:col-span-2 md:col-span-2' : ''}`}
            style={`background-color: var(--color-surface);
              border: 1px solid ${isDestaque ? 'rgba(212,160,23,0.5)' : 'rgba(255,255,255,0.06)'};`}
          >
            <!-- Top gradient bar -->
            <div
              class="h-1 w-full shrink-0"
              style={`background: linear-gradient(90deg, ${badge?.bg ?? 'var(--color-primary)'}, var(--color-secondary));`}
            ></div>

            <div class="flex flex-col flex-1 p-6">
              <!-- Date + badge row -->
              <div class="flex items-start justify-between gap-3 mb-4">
                <!-- Calendar + date -->
                <div class="flex items-center gap-3">
                  <div
                    class="flex flex-col items-center justify-center w-12 h-12 rounded-xl shrink-0"
                    style="background-color: rgba(212,160,23,0.1); border: 1px solid rgba(212,160,23,0.2);"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mb-0.5" style="color: var(--color-primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span class="text-xs font-bold leading-none" style="color: var(--color-primary);">{evento.data}</span>
                  </div>
                  <div>
                    <span class="text-xs font-medium uppercase tracking-wider" style="color: var(--color-cream-muted);">{evento.diaSemana}</span>
                    <p class="text-xs" style="color: rgba(245,240,232,0.5);">Salvador, BA</p>
                  </div>
                </div>

                <!-- Tag badges -->
                <div class="flex flex-col items-end gap-1">
                  {isDestaque && (
                    <span
                      class="px-2.5 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase"
                      style="background-color: rgba(212,160,23,0.2); color: var(--color-primary); border: 1px solid rgba(212,160,23,0.4);"
                    >
                      EM DESTAQUE
                    </span>
                  )}
                  {evento.tag && !isDestaque && (
                    <span
                      class="px-2.5 py-1 rounded-full text-[10px] font-bold tracking-wide"
                      style="background-color: rgba(212,160,23,0.12); color: var(--color-primary); border: 1px solid rgba(212,160,23,0.25);"
                    >
                      {evento.tag}
                    </span>
                  )}
                </div>
              </div>

              <!-- Artist name -->
              <h3
                class="text-xl font-bold mb-2 group-hover:transition-colors duration-300"
                style="font-family: var(--font-playfair); color: var(--color-cream);"
              >
                {evento.artista}
              </h3>

              <!-- Genre badge -->
              {badge && (
                <span
                  class="inline-block w-fit px-3 py-1 rounded-full text-xs font-bold mb-3"
                  style={`background-color: ${badge.bg}22; color: ${badge.bg}; border: 1px solid ${badge.bg}44;`}
                >
                  {evento.estilo}
                </span>
              )}

              <!-- Description -->
              <p class="text-sm leading-relaxed flex-1 mb-5" style="color: var(--color-cream-muted);">
                {evento.descricao}
              </p>

              <!-- CTA -->
              <a
                href={WA_INGRESSO}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full py-3 rounded-xl text-sm font-bold
                       transition-all duration-300 hover:scale-105"
                style="background-color: var(--color-primary); color: #000;
                       box-shadow: 0 4px 16px rgba(212,160,23,0.35);"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Garantir Ingresso
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
